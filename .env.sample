# Azure Kusto/Fabric Configuration
CLUSTER_URL=
DATABASE_NAME=
KUSTO_CLIENT_ID=
KUSTO_CLIENT_SECRET=
KUSTO_TENANT_ID=

# PostgreSQL Configuration
POSTGRES_CONNECTION_STRING=postgresql://username:password@hostname:5432/database_name

# Service Feature Flags (true/false)
ENABLE_DATA_TOOLS=true
ENABLE_FABRIC_RTI_TOOLS=true
ENABLE_GIT_CLI_TOOLS=true
ENABLE_INSTRUCTION_TOOLS=true
ENABLE_POSTGRESQL_READ_TOOLS=false
ENABLE_POSTGRESQL_WRITE_TOOLS=false